# Anthropic Claude API-Key fuer die Energieausweis-Extraktion (KI-Vision).
# Ohne diesen Key funktioniert der Upload nicht; der Beispiel-Ausweis
# ("Mit Beispiel-Ausweis testen") laeuft jedoch auch ohne Key.
ANTHROPIC_API_KEY=

# Optional: Claude-Modell fuer die Ausweis-Extraktion (Default: claude-sonnet-4-5)
# ANTHROPIC_MODEL=claude-sonnet-4-5

# --- Fassaden-/WWR-Analyse (Google Street View) -----------------------------
# Server-Key: Street View Static API + Maps Static API (Satellit-Fallback).
# Ohne Key faellt die App automatisch auf den Typologie-Standardwert zurueck.
GOOGLE_MAPS_API_KEY=

# Browser-Key fuer die schraege Luftansicht (Photorealistic 3D Tiles / Map Tiles API).
# WIRD IM CLIENT SICHTBAR -> zwingend per HTTP-Referrer einschraenken und nur
# "Map Tiles API" erlauben. Ohne Key -> Fallback auf Satellit-Top-Down.
NEXT_PUBLIC_GOOGLE_MAPS_KEY=

# Optional: guenstiges Vision-Modell fuer die WWR-Schaetzung (Default: claude-haiku-4-5)
# FACADE_MODEL=claude-haiku-4-5

# Optional: Fassaden-Feature komplett deaktivieren (kein Bildabruf) mit "false"
# FACADE_ENABLED=true

# --- Persistenz & Auth (Phase 1) ---------------------------------------------
# Neon Postgres (Vercel Marketplace). Ohne DATABASE_URL laeuft nur der
# zustandslose Modus (sessionStorage, kein Portfolio).
# Lokal beziehen mit: vercel env pull .env.local
DATABASE_URL=

# Clerk (Vercel Marketplace). Public Sign-up ist deaktiviert (Restricted Mode);
# User werden vom Admin unter /admin angelegt/eingeladen.
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=

# Clerk-Routing: eigene In-App-Sign-in-Seite statt Clerk Account Portal.
# Wichtig fuer die Middleware-Redirects (auth.protect).
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/portfolio
